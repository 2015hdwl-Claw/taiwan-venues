{
  "version": 2,
  "name": "taiwan-venue-api",
  "public": true,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/health",
      "destination": "/api/index.js"
    },
    {
      "source": "/script.js",
      "destination": "/api/index.js"
    },
    {
      "source": "/style.css",
      "destination": "/api/index.js"
    },
    {
      "source": "/",
      "destination": "/api/index.js"
    }
  ]
}
